<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BcvExchangeApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BcvExchangeApp"
    Title="BcvExchangeApp"
    FlyoutBehavior="Flyout">

    <FlyoutItem Title="Inicio"
            Route="MainPage">
        <ShellContent
            ContentTemplate="{DataTemplate local:MainPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Datos de Pago Móvil"
            Route="PagoMovilPage">
        <ShellContent
            ContentTemplate="{DataTemplate local:PagoMovilPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Gestor de Compras" Route="Compras">
        <ShellContent ContentTemplate="{DataTemplate local:Compras}"/>
    </FlyoutItem>

</Shell>
